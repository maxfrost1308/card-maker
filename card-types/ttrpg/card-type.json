{
  "id": "ttrpg",
  "name": "TTRPG Cards",
  "description": "Reference cards for tabletop role-playing games. Front shows pitch and hook, back shows specs and QR code.",
  "cardSize": {
    "width": "63.5mm",
    "height": "88.9mm"
  },
  "fields": [
    {
      "key": "title",
      "label": "Title",
