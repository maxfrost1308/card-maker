      "options": ["Story Game", "Traditional RPG", "OSR", "Narrative RPG", "LARP", "Board Game Hybrid"]
    },
    {
      "key": "genre",
      "label": "Genre",
      "type": "multi-select",
      "separator": "|",
      "options": ["fantasy", "sci-fi", "horror", "dark", "modern", "romance", "mystery", "weird", "gonzo", "cozy", "drama", "comedy", "supernatural", "any"],
      "pillColors": {
        "fantasy": "#6a4c93",
        "sci-fi": "#2e86ab",
        "horror": "#8b1a1a",
        "dark": "#444444",
        "modern": "#5b7553",
        "romance": "#c44569",
        "mystery": "#3c3c6e",
        "weird": "#b8560b",
        "gonzo": "#e07b00",
        "cozy": "#7bb369",
        "drama": "#7a5195",
        "comedy": "#d4a017",
        "supernatural": "#6b4c8a",
        "any": "#666666"
      }
    },
    {
      "key": "players",
      "label": "Players",
      "type": "text"
    },
    {
      "key": "time",
      "label": "Time (min)",
      "type": "text"
    },
    {
      "key": "complexity",
      "label": "Complexity",
      "type": "text"
    },
    {
      "key": "gm_structure",
      "label": "GM Structure",
      "type": "select",
      "options": ["GM-led", "Facilitated", "GM-less", "Solo"]
    },
    {
      "key": "campaign_type",
      "label": "Campaign Type",
      "type": "select",
      "options": ["One-Shot", "Short", "Long"]
    },
