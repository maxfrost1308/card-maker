      "separator": "|",
      "options": [
        "Custom cards",
        "Standard cards",
        "Character sheets",
        "Polyhedral dice",
        "D6 only",
        "Stackable dice",
        "Jenga tower",
        "Tokens",
        "Coins",
        "Map",
        "Playmat",
        "Paper & pencil",
        "Rules booklet",
        "One page RPG",
        "No components",
        "Specialty"
      ]
    },
    {
      "key": "link",
      "label": "Link",
      "type": "url"
    },
    {
      "key": "back_color",
      "label": "Back Color",
      "type": "text"
    },
    {
      "key": "verified_fields",
      "label": "Verified Fields",
      "type": "text"
    },
    {
      "key": "to_play",
      "label": "To Play",
